# Copy this file to .env and tweak values as needed.

# Pro mode defaults
FASTEST_RESPONSE_MODE=0
ENABLE_QUERY_REWRITE=1
ENABLE_CLARIFICATION_GATE=1
ENABLE_SELF_CHECK=1

# Generation budget
GENERATION_MAX_NEW_TOKENS=256
REWRITE_MAX_NEW_TOKENS=24
GENERATION_MAX_TIME_SEC=30

# Retrieval and rerank
TOP_K=3
SIMILARITY_THRESHOLD=40
RETRIEVAL_CANDIDATE_MULTIPLIER=4
RERANK_EMBEDDING_WEIGHT=0.75
RERANK_KEYWORD_WEIGHT=0.25

# Chunking
MIN_CHUNK_CHARS=120
ENABLE_CHUNK_DEDUP=1
MAX_CHUNKS_PER_SECTION=250
PDF_MARGIN_REPEAT_RATIO=0.8
